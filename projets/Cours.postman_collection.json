        {
          "listen": "test",
          "script": {
            "exec": [
              "var template = `",
              "<canvas id=\"myChart\" height=\"75\"></canvas>",
              "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"><\\/script>",
              "<script>",
              "  pm.getData(function(err, value) {",
              "    var data = value.response;",
              "    if (!data || data.length === 0) {",
              "      document.getElementById('myChart').style.display = 'none';",
              "      var msg = document.createElement('p');",
              "      msg.innerText = 'No data available';",
              "      msg.style.textAlign = 'center';",
              "      msg.style.fontSize = '18px';",
              "      document.body.appendChild(msg);",
              "      return;",
              "    }",
              "    var ctx = document.getElementById('myChart');",
              "    new Chart(ctx, {",
              "      type: 'bar',",
              "      data: {",
              "        labels: data.map(function(c) { return c.titre; }),",
              "        datasets: [{",
              "          label: 'Volume Horaire (h)',",
              "          data: data.map(function(c) { return c.volumeHoraire; }),",
              "          backgroundColor: 'rgba(54, 162, 235, 0.6)',",
              "          borderColor: 'rgba(54, 162, 235, 1)',",
              "          borderWidth: 1",
              "        }]",
              "      },",
              "      options: {",
              "        title: { display: true, text: 'Cours - Volume Horaire' },",
              "        scales: {",
              "          xAxes: [{ scaleLabel: { display: true, labelString: 'Titre du Cours' } }],",
              "          yAxes: [{ scaleLabel: { display: true, labelString: 'Volume Horaire (h)' }, ticks: { beginAtZero: true } }]",
              "        }",
              "      }",
              "    });",
              "  });",
              "<\\/script>`;",
              "",
              "function constructVisualizerPayload() {",
              "  return { response: pm.response.json() };",
              "}",
              "",
              "pm.visualizer.set(template, constructVisualizerPayload());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
